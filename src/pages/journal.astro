---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Journal — Caelus Industries">

<div class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-content">
    <div class="page-tag">Journal</div>
    <h1 class="page-title">Latest articles</h1>
    <p class="page-subtitle">Insights on autonomous systems, counter-UAS operations, and the future of unmanned platforms.</p>
  </div>
</div>

<div class="divider"></div>

<div class="content-section">
  <div class="journal-grid">
    <div class="journal-item">
      <div class="journal-date">Insights · 4 min</div>
      <div class="journal-content">
        <div class="journal-title">Article Title Placeholder</div>
        <p class="journal-excerpt">Article excerpt or summary placeholder. Describe the key insight or finding covered in this piece.</p>
        <span class="journal-tag">Counter-UAS</span>
      </div>
    </div>
    <div class="journal-item">
      <div class="journal-date">Insights · 6 min</div>
      <div class="journal-content">
        <div class="journal-title">Article Title Placeholder</div>
        <p class="journal-excerpt">Article excerpt or summary placeholder. Add the real content when available.</p>
        <span class="journal-tag">Maritime</span>
      </div>
    </div>
    <div class="journal-item">
      <div class="journal-date">Insights · 5 min</div>
      <div class="journal-content">
        <div class="journal-title">Article Title Placeholder</div>
        <p class="journal-excerpt">Article excerpt or summary placeholder. Add the real content when available.</p>
        <span class="journal-tag">Autonomy</span>
      </div>
    </div>
  </div>

  <div class="subscribe-bar">
    <p>Subscribe to Caelus Journal</p>
    <div class="subscribe-form">
      <input class="subscribe-input" type="email" placeholder="your@email.com"/>
      <button class="btn-primary" style="padding:10px 20px">Subscribe</button>
    </div>
  </div>
</div>

</Layout>
