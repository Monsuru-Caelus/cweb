---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Careers — Caelus Industries" description="Join Caelus Industries. We're hiring engineers and builders who want to work on autonomous maritime and counter-UAS systems that matter.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://caelusindustries.com" },
        { "@type": "ListItem", "position": 2, "name": "Careers", "item": "https://caelusindustries.com/careers" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "Embedded Systems Engineer",
      "description": "Build the firmware and sensor fusion pipelines that power our autonomous platforms. Experience with RTOS, SLAM, and edge AI inference preferred.",
      "hiringOrganization": { "@type": "Organization", "name": "Caelus Industries", "sameAs": "https://caelusindustries.com" },
      "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "San Francisco", "addressRegion": "CA", "addressCountry": "US" } },
      "employmentType": "FULL_TIME",
      "datePosted": "2026-01-01"
    },
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "ML / Computer Vision Engineer",
      "description": "Develop and deploy perception models for real-time threat detection. Work spans from training pipelines to edge deployment on Jetson hardware.",
      "hiringOrganization": { "@type": "Organization", "name": "Caelus Industries", "sameAs": "https://caelusindustries.com" },
      "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "Remote", "addressCountry": "US" } },
      "employmentType": "FULL_TIME",
      "datePosted": "2026-01-01"
    },
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "UX Designer",
      "description": "Shape the interfaces that operators rely on in high-stakes environments. Lead cross-functional teams to build thoughtful, scalable solutions for defense-forward organizations.",
      "hiringOrganization": { "@type": "Organization", "name": "Caelus Industries", "sameAs": "https://caelusindustries.com" },
      "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "San Francisco", "addressRegion": "CA", "addressCountry": "US" } },
      "employmentType": "CONTRACTOR",
      "datePosted": "2026-01-01"
    }
  ])}/>

<div class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-content">
    <div class="page-tag">Careers</div>
    <h1 class="page-title">Careers at<br/>Caelus</h1>
    <p class="page-subtitle">We're building autonomous systems for the hardest environments on earth. Join us if you want your work to matter.</p>
  </div>
</div>

<div class="divider"></div>

<div class="content-section">
  <div class="section-label" style="margin-bottom:0">Open roles</div>
  <div class="jobs-list">
    <div class="job-item" data-role="Application — UX Designer">
      <div>
        <div class="job-title">UX Designer</div>
        <p class="job-desc">Shape the interfaces that operators rely on in high-stakes environments. You'll lead cross-functional teams to build thoughtful, scalable solutions for defense-forward organizations.</p>
        <div class="job-meta">
          <span class="job-type">Contract</span>
          <span>·</span>
          <span>San Francisco, CA</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </div>
    <div class="job-item" data-role="Application — Embedded Systems Engineer">
      <div>
        <div class="job-title">Embedded Systems Engineer</div>
        <p class="job-desc">Build the firmware and sensor fusion pipelines that power our autonomous platforms. Experience with RTOS, SLAM, and edge AI inference preferred.</p>
        <div class="job-meta">
          <span class="job-type">Full-time</span>
          <span>·</span>
          <span>Remote / Bay Area</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </div>
    <div class="job-item" data-role="Application — ML / Computer Vision Engineer">
      <div>
        <div class="job-title">ML / Computer Vision Engineer</div>
        <p class="job-desc">Develop and deploy perception models for real-time threat detection. Work spans from training pipelines to edge deployment on Jetson hardware.</p>
        <div class="job-meta">
          <span class="job-type">Full-time</span>
          <span>·</span>
          <span>Remote</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </div>
    <div class="job-item" data-role="Open Application — Caelus Industries">
      <div>
        <div class="job-title">Open application</div>
        <p class="job-desc">Don't see your role available? Apply for an open application — we're always looking for exceptional people building at the frontier of autonomy and defense.</p>
        <div class="job-meta">
          <span class="job-type">All roles</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </div>
  </div>
</div>

<aside class="cta-aside">
  <h4>Ready to build systems that matter?</h4>
  <a href="/contact" class="btn-dark">
    <span style="width:4px;height:4px;border-radius:50%;background:#fff"></span>
    Get in touch
  </a>
</aside>

<!-- Application modal -->
<div id="apply-overlay" class="apply-overlay" style="display:none">
  <div class="apply-modal">
    <div class="apply-modal-header">
      <div class="apply-modal-title">Apply</div>
      <button class="apply-close" id="apply-close" aria-label="Close">✕</button>
    </div>
    <form class="apply-form" id="apply-form">
      <input type="hidden" name="subject" id="apply-subject"/>
      <div class="form-group">
        <label class="form-label">NAME</label>
        <input class="form-input" type="text" name="name" placeholder="Jane Smith" required/>
      </div>
      <div class="form-group">
        <label class="form-label">EMAIL</label>
        <input class="form-input" type="email" name="email" placeholder="jane@example.com" required/>
      </div>
      <div class="form-group">
        <label class="form-label">SUBJECT</label>
        <input class="form-input" type="text" name="subject_display" id="apply-subject-display" placeholder="Role you're applying for" required/>
      </div>
      <div class="form-group">
        <label class="form-label">MESSAGE</label>
        <textarea class="form-textarea" name="message" placeholder="Tell us about yourself and why you want to join Caelus..." required></textarea>
      </div>
      <button type="submit" class="btn-primary" id="apply-submit" style="align-self:flex-start">
        <span class="btn-dot"></span>
        <span id="apply-submit-label">Send application</span>
      </button>
      <p id="apply-success" style="display:none;font-family:var(--font-mono);font-size:13px;color:rgba(255,255,255,0.6);margin-top:8px;">Application sent — we'll be in touch shortly.</p>
      <p id="apply-error" style="display:none;font-family:var(--font-mono);font-size:13px;color:rgba(255,80,80,0.8);margin-top:8px;">Something went wrong. Please try again or email us directly.</p>
    </form>
  </div>
</div>

<script is:inline>
  function openApplyModal(role) {
    document.getElementById('apply-subject').value = role;
    document.getElementById('apply-subject-display').value = role;
    document.getElementById('apply-success').style.display = 'none';
    document.getElementById('apply-error').style.display = 'none';
    document.getElementById('apply-form').reset();
    document.getElementById('apply-subject').value = role;
    document.getElementById('apply-subject-display').value = role;
    document.getElementById('apply-overlay').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeApplyModal() {
    document.getElementById('apply-overlay').style.display = 'none';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.job-item').forEach(function(item) {
    item.addEventListener('click', function() {
      openApplyModal(this.dataset.role);
    });
  });

  document.getElementById('apply-close').addEventListener('click', closeApplyModal);

  document.getElementById('apply-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeApplyModal();
  });

  document.getElementById('apply-form').addEventListener('submit', async function(e) {
    e.preventDefault();

    const btn = document.getElementById('apply-submit');
    const label = document.getElementById('apply-submit-label');
    const success = document.getElementById('apply-success');
    const error = document.getElementById('apply-error');

    // sync hidden subject with display field
    document.getElementById('apply-subject').value = document.getElementById('apply-subject-display').value;

    const formData = new FormData(this);
    // use the display field value as the actual subject sent to the API
    formData.set('subject', document.getElementById('apply-subject-display').value);

    btn.disabled = true;
    label.textContent = 'Sending...';
    success.style.display = 'none';
    error.style.display = 'none';

    try {
      const res = await fetch('/api/apply', { method: 'POST', body: formData });
      const json = await res.json();
      if (res.ok && json.success) {
        success.style.display = 'block';
        this.reset();
      } else {
        error.style.display = 'block';
      }
    } catch {
      error.style.display = 'block';
    } finally {
      btn.disabled = false;
      label.textContent = 'Send application';
    }
  });
</script>

</Layout>
