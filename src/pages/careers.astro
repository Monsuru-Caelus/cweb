---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Careers — Caelus Industries" description="Join Caelus Industries. We're hiring engineers and builders who want to work on autonomous maritime and counter-UAS systems that matter.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://caelusindustries.com" },
        { "@type": "ListItem", "position": 2, "name": "Careers", "item": "https://caelusindustries.com/careers" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "Embedded Systems Engineer",
      "description": "Build the firmware and sensor fusion pipelines that power our autonomous platforms. Experience with RTOS, SLAM, and edge AI inference preferred.",
      "hiringOrganization": { "@type": "Organization", "name": "Caelus Industries", "sameAs": "https://caelusindustries.com" },
      "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "San Francisco", "addressRegion": "CA", "addressCountry": "US" } },
      "employmentType": "FULL_TIME",
      "datePosted": "2026-01-01"
    },
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "ML / Computer Vision Engineer",
      "description": "Develop and deploy perception models for real-time threat detection. Work spans from training pipelines to edge deployment on Jetson hardware.",
      "hiringOrganization": { "@type": "Organization", "name": "Caelus Industries", "sameAs": "https://caelusindustries.com" },
      "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "Remote", "addressCountry": "US" } },
      "employmentType": "FULL_TIME",
      "datePosted": "2026-01-01"
    },
    {
      "@context": "https://schema.org",
      "@type": "JobPosting",
      "title": "UX Designer",
      "description": "Shape the interfaces that operators rely on in high-stakes environments. Lead cross-functional teams to build thoughtful, scalable solutions for defense-forward organizations.",
      "hiringOrganization": { "@type": "Organization", "name": "Caelus Industries", "sameAs": "https://caelusindustries.com" },
      "jobLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "San Francisco", "addressRegion": "CA", "addressCountry": "US" } },
      "employmentType": "CONTRACTOR",
      "datePosted": "2026-01-01"
    }
  ])}/>

<div class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-content">
    <div class="page-tag">Careers</div>
    <h1 class="page-title">Careers at<br/>Caelus</h1>
    <p class="page-subtitle">We're building autonomous systems for the hardest environments on earth. Join us if you want your work to matter.</p>
  </div>
</div>

<div class="divider"></div>

<div class="content-section">
  <div class="section-label" style="margin-bottom:0">Open roles</div>
  <div class="jobs-list">
    <a href="mailto:contact@caelusindustries.com?subject=Application%20%E2%80%94%20UX%20Designer" class="job-item">
      <div>
        <div class="job-title">UX Designer</div>
        <p class="job-desc">Shape the interfaces that operators rely on in high-stakes environments. You'll lead cross-functional teams to build thoughtful, scalable solutions for defense-forward organizations.</p>
        <div class="job-meta">
          <span class="job-type">Contract</span>
          <span>·</span>
          <span>San Francisco, CA</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </a>
    <a href="mailto:contact@caelusindustries.com?subject=Application%20%E2%80%94%20Embedded%20Systems%20Engineer" class="job-item">
      <div>
        <div class="job-title">Embedded Systems Engineer</div>
        <p class="job-desc">Build the firmware and sensor fusion pipelines that power our autonomous platforms. Experience with RTOS, SLAM, and edge AI inference preferred.</p>
        <div class="job-meta">
          <span class="job-type">Full-time</span>
          <span>·</span>
          <span>Remote / Bay Area</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </a>
    <a href="mailto:contact@caelusindustries.com?subject=Application%20%E2%80%94%20ML%20%2F%20Computer%20Vision%20Engineer" class="job-item">
      <div>
        <div class="job-title">ML / Computer Vision Engineer</div>
        <p class="job-desc">Develop and deploy perception models for real-time threat detection. Work spans from training pipelines to edge deployment on Jetson hardware.</p>
        <div class="job-meta">
          <span class="job-type">Full-time</span>
          <span>·</span>
          <span>Remote</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </a>
    <a href="mailto:contact@caelusindustries.com?subject=Open%20Application%20%E2%80%94%20Caelus%20Industries" class="job-item">
      <div>
        <div class="job-title">Open application</div>
        <p class="job-desc">Don't see your role available? Apply for an open application — we're always looking for exceptional people building at the frontier of autonomy and defense.</p>
        <div class="job-meta">
          <span class="job-type">All roles</span>
        </div>
      </div>
      <div class="job-arrow">→</div>
    </a>
  </div>
</div>

<aside class="cta-aside">
  <h4>Ready to build systems that matter?</h4>
  <a href="/contact" class="btn-dark">
    <span style="width:4px;height:4px;border-radius:50%;background:#fff"></span>
    Get in touch
  </a>
</aside>

</Layout>
