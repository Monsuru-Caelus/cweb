---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Products — Caelus Industries" description="Explore Caelus Industries' autonomous platforms: MUKAGEN counter-UAS weapon station, YEMOJA sUSV maritime patrol vessel, and Condor loitering strike munition.">

<div class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-content">
    <div class="page-tag">Products</div>
    <h1 class="page-title">Autonomous platforms<br/>built for real threats</h1>
    <p class="page-subtitle">Edge-deployed systems for counter-UAS, maritime patrol, and multi-domain threat detection.</p>
  </div>
</div>

<div class="divider"></div>

<!-- FEATURE HIGHLIGHTS -->
<div class="content-section">
<div style="display:flex;gap:2px;flex-wrap:wrap">
    <div class="value-item" style="text-align:center;align-items:center;display:flex;flex-direction:column;gap:8px">
      <div style="font-family:var(--font-mono);font-size:24px;color:var(--white)">001</div>
      <div class="value-title" style="font-size:16px">Detect</div>
    </div>
    <div class="value-item" style="text-align:center;align-items:center;display:flex;flex-direction:column;gap:8px">
      <div style="font-family:var(--font-mono);font-size:24px;color:var(--white)">002</div>
      <div class="value-title" style="font-size:16px">Track</div>
    </div>
    <div class="value-item" style="text-align:center;align-items:center;display:flex;flex-direction:column;gap:8px">
      <div style="font-family:var(--font-mono);font-size:24px;color:var(--white)">003</div>
      <div class="value-title" style="font-size:16px">Classify</div>
    </div>
    <div class="value-item" style="text-align:center;align-items:center;display:flex;flex-direction:column;gap:8px">
      <div style="font-family:var(--font-mono);font-size:24px;color:var(--white)">004</div>
      <div class="value-title" style="font-size:16px">Respond</div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- PRODUCTS -->
<div class="content-section">
  <div class="section-label" style="margin-bottom:40px">Our platforms</div>
  <div style="display:flex;flex-direction:column;gap:2px">
    <a href="/products/mukagen" style="text-decoration:none">
      <div class="platform-row">
        <div class="platform-thumb" style="background:#0f0f18;overflow:hidden;padding:0"><img src="/images/mukagen.png" alt="MUKAGEN" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"/></div>
        <div style="flex:1">
          <div style="font-family:var(--font-sans);font-weight:500;font-size:28px;letter-spacing:-0.03em;color:var(--white);margin-bottom:8px">MUKAGEN</div>
          <p style="font-family:var(--font-serif);font-size:18px;letter-spacing:-0.03em;line-height:1.4;color:rgba(255,255,255,0.6)">Modular Counter-UAS Weapon Station</p>
          <p style="font-family:var(--font-body);font-style:italic;font-size:14px;color:var(--white);text-decoration:underline;margin-top:12px">Learn more →</p>
        </div>
      </div>
    </a>
    <a href="/products/yemoja-susv" style="text-decoration:none">
      <div class="platform-row">
        <div class="platform-thumb" style="background:#0a1018;overflow:hidden;padding:0"><img src="/images/yemoja.jpeg" alt="YEMOJA sUSV" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"/></div>
        <div style="flex:1">
          <div style="font-family:var(--font-sans);font-weight:500;font-size:28px;letter-spacing:-0.03em;color:var(--white);margin-bottom:8px">YEMOJA sUSV</div>
          <p style="font-family:var(--font-serif);font-size:18px;letter-spacing:-0.03em;line-height:1.4;color:rgba(255,255,255,0.6)">Autonomous Surface Patrol Vessel</p>
          <p style="font-family:var(--font-body);font-style:italic;font-size:14px;color:var(--white);text-decoration:underline;margin-top:12px">Learn more →</p>
        </div>
      </div>
    </a>
    <a href="/products/condor" style="text-decoration:none">
      <div class="platform-row">
        <div class="platform-thumb" style="background:#0a1410;overflow:hidden;padding:0"><img src="/images/condor.jpeg" alt="Condor" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"/></div>
        <div style="flex:1">
          <div style="font-family:var(--font-sans);font-weight:500;font-size:28px;letter-spacing:-0.03em;color:var(--white);margin-bottom:8px">Condor</div>
          <p style="font-family:var(--font-serif);font-size:18px;letter-spacing:-0.03em;line-height:1.4;color:rgba(255,255,255,0.6)">Loitering Strike Munition</p>
          <p style="font-family:var(--font-body);font-style:italic;font-size:14px;color:var(--white);text-decoration:underline;margin-top:12px">Learn more →</p>
        </div>
      </div>
    </a>
  </div>
</div>

<aside class="cta-aside">
  <h4>Ready to operationalize your vigilance goals?</h4>
  <a href="/contact" class="btn-dark">
    <span style="width:4px;height:4px;border-radius:50%;background:#fff"></span>
    Request a demo
  </a>
</aside>

</Layout>
