---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="YEMOJA sUSV — Caelus Industries">

<!-- HERO IMAGE WITH TITLE OVERLAY -->
<div style="position:relative;width:100%;margin-top:60px;">
  <img src="/images/yemoja.jpeg" alt="YEMOJA sUSV" style="width:100%;height:auto;display:block;"/>
  <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.1) 100%);"></div>
  <div style="position:absolute;bottom:0;left:0;right:0;padding:48px 40px;max-width:1240px;margin:0 auto;">
    <div class="page-tag" style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
      <a href="/products" style="color:var(--muted);font-family:var(--font-mono);font-size:12px;letter-spacing:0.1em;text-decoration:none">Products</a>
      <span style="color:var(--muted)">·</span>
      <span style="color:var(--muted);font-family:var(--font-mono);font-size:12px;">4 min read</span>
    </div>
    <h1 class="page-title">YEMOJA sUSV</h1>
    <p class="page-subtitle">Autonomous Surface Patrol Vessel</p>
  </div>
</div>

<!-- TABS -->
<div style="max-width:1240px;margin:0 auto;padding:0 40px">
  <div class="product-tabs">
    <button class="tab-btn active" onclick="showTab('features',this)">KEY FEATURES</button>
    <button class="tab-btn" onclick="showTab('specs',this)">SPECIFICATIONS</button>
    <button class="tab-btn" onclick="showTab('configs',this)">CONFIGURATIONS</button>
    <button class="tab-btn" onclick="showTab('deployment',this)">DEPLOYMENT</button>
    <button class="tab-btn" onclick="showTab('addons',this)">ADD-ONS</button>
  </div>

  <div id="tab-features" class="tab-content active">
    <div class="feature-list">
      <div class="feature-item">
        <div class="feature-title">Autonomous surface navigation</div>
        <p class="feature-body">Maritime Robotics autonomous navigation system with COLREGS-compliant operation. Supports full autonomous, remote, and formation modes out of the box. Controllable via VCS Rugged Laptop or Android app, with external 3rd party software integration available.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Persistent maritime surveillance</div>
        <p class="feature-body">24-hour endurance at 2 knots on a single battery charge. Rated to Beaufort sea state 4. Designed for unattended extended patrol without operator intervention.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Multi-sensor payload bay</div>
        <p class="feature-body">30 kg payload capacity with modular sensor architecture. Standard configuration includes EO camera and AIS Class B receiver. Upgradeable to SeaSight enhanced awareness with AIS Class B transceiver.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">RF and acoustic comms</div>
        <p class="feature-body">5GHz MIMO radio/WiFi standard. Optional LTE (4G), VHF, and MBR add-ons for multi-layer comms redundancy across contested or degraded RF environments.</p>
      </div>
    </div>
  </div>

  <div id="tab-specs" class="tab-content">
    <div class="specs-grid">
      <div class="spec-item"><div class="spec-label">VESSEL CLASS</div><div class="spec-value">sUSV</div></div>
      <div class="spec-item"><div class="spec-label">PROPULSION</div><div class="spec-value">2× electric motors</div></div>
      <div class="spec-item"><div class="spec-label">ENDURANCE</div><div class="spec-value">24 hours at 2 knots</div></div>
      <div class="spec-item"><div class="spec-label">MAX SPEED</div><div class="spec-value">5 knots</div></div>
      <div class="spec-item"><div class="spec-label">PAYLOAD CAPACITY</div><div class="spec-value">30 kg</div></div>
      <div class="spec-item"><div class="spec-label">COMMS</div><div class="spec-value">5GHz MIMO / WiFi (+ optional LTE, VHF, MBR)</div></div>
      <div class="spec-item"><div class="spec-label">NAVIGATION</div><div class="spec-value">Autonomous / COLREGS</div></div>
      <div class="spec-item"><div class="spec-label">WEIGHT</div><div class="spec-value">85 kg (with batteries)</div></div>
    </div>
  </div>

  <div id="tab-configs" class="tab-content">
    <div class="feature-list">
      <div class="feature-item">
        <div class="feature-title">Configuration A — Standard</div>
        <p class="feature-body">Complete platform with 2× electric motors, 4× lithium-ion batteries, Maritime Robotics autonomous navigation, VCS Rugged Laptop and Android app, EO camera, AIS Class B receiver, and 5GHz MIMO/WiFi. Ready for autonomous or remote operation out of the box.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Configuration B — Enhanced</div>
        <p class="feature-body">Standard platform plus SeaSight enhanced situational awareness, AIS Class B transceiver, and SeaCapture data logging. Suited for persistent ISR and data-collection missions requiring full maritime picture.</p>
      </div>
    </div>
  </div>

  <div id="tab-deployment" class="tab-content">
    <div class="feature-list">
      <div class="feature-item">
        <div class="feature-title">Operational deployment</div>
        <p class="feature-body">Yemoja deploys from vessel, dock, or shoreline and achieves autonomous operation immediately on water contact. Operator monitors and retasks via laptop or Android app. Formation mode supports coordinated multi-USV patrol without additional infrastructure. Optional launch and recovery crane kit and ruggedised flight cases available for expeditionary deployment.</p>
      </div>
    </div>
  </div>

  <div id="tab-addons" class="tab-content">
    <div class="feature-list">
      <div class="feature-item">
        <div class="feature-title">Additional comms</div>
        <p class="feature-body">MBR / VHF / LTE (4G) add-ons for multi-layer comms redundancy across contested or degraded RF environments.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Enhanced awareness</div>
        <p class="feature-body">SeaSight situational awareness package with AIS Class B transceiver upgrade.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">SeaCapture data logging</div>
        <p class="feature-body">Full-mission data capture and logging software for persistent ISR and post-mission analysis.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Formation mode</div>
        <p class="feature-body">Coordinated multi-USV patrol operations without additional ground infrastructure.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Expeditionary kit</div>
        <p class="feature-body">Launch and recovery crane kit and ruggedised flight cases for rapid forward deployment from vessel or shore.</p>
      </div>
      <div class="feature-item">
        <div class="feature-title">Additional integrations</div>
        <p class="feature-body">External 3rd party software integration, Autocast SVP winch, and custom payload configurations available on request.</p>
      </div>
    </div>
  </div>
</div>

<div style="height:80px"></div>

<aside class="cta-aside">
  <h4>Interested in YEMOJA sUSV?</h4>
  <a href="/contact" class="btn-dark">
    <span style="width:4px;height:4px;border-radius:50%;background:#fff"></span>
    Request a demo
  </a>
</aside>

<script is:inline>
function showTab(id, btn) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}
</script>

</Layout>
