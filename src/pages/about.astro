---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About — Caelus Industries">

<div class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-content">
    <div class="page-tag">About</div>
    <h1 class="page-title">Our mission</h1>
    <p class="page-subtitle">Caelus Industries builds autonomous platforms for counter-UAS, maritime patrol, and multi-domain threat detection in high-stakes environments.</p>
  </div>
</div>

<div class="divider"></div>

<!-- VALUES -->
<div class="content-section">
  <div class="section-label" style="margin-bottom:0">Our values</div>
  <div class="values-grid">
    <div class="value-item">
      <div class="value-num">01</div>
      <div class="value-title">Clarity drives security</div>
      <p class="value-body">We believe superior operations start with superior intelligence — detected, analyzed, and actionable. Ambiguity costs lives; clarity wins missions.</p>
    </div>
    <div class="value-item">
      <div class="value-num">02</div>
      <div class="value-title">Defense is a systems challenge</div>
      <p class="value-body">We engineer platforms that help teams integrate surveillance, threat classification, and response across unmanned assets — air, sea, and ground.</p>
    </div>
    <div class="value-item">
      <div class="value-num">03</div>
      <div class="value-title">Readiness over rigidity</div>
      <p class="value-body">We enable real-world dominance, guiding forces from strategy to mission-critical execution. Our systems adapt to the environment, not the other way around.</p>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- TEAM -->
<div class="content-section">
  <div class="section-label" style="margin-bottom:40px">Meet the team</div>
  <div class="team-grid">
    <div class="team-card">
      <div class="team-photo">PHOTO</div>
      <div class="team-info">
        <div class="team-name">Name</div>
        <div class="team-title">Title</div>
      </div>
    </div>
    <div class="team-card">
      <div class="team-photo">PHOTO</div>
      <div class="team-info">
        <div class="team-name">Name</div>
        <div class="team-title">Title</div>
      </div>
    </div>
    <div class="team-card">
      <div class="team-photo">PHOTO</div>
      <div class="team-info">
        <div class="team-name">Name</div>
        <div class="team-title">Title</div>
      </div>
    </div>
    <div class="team-card">
      <div class="team-photo">PHOTO</div>
      <div class="team-info">
        <div class="team-name">Name</div>
        <div class="team-title">Title</div>
      </div>
    </div>
  </div>
  <div style="margin-top:40px;text-align:center">
    <a href="/careers" class="btn-primary" style="display:inline-flex">
      <span class="btn-dot"></span>
      We're hiring! Want to join the team?
    </a>
  </div>
</div>

</Layout>
