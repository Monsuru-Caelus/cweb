---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Caelus Industries — Autonomous Maritime & Counter-UAS Defense Systems"
  description="Caelus Industries builds autonomous platforms for counter-UAS, maritime patrol, and multi-domain threat detection in high-stakes environments."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Caelus Industries",
    "url": "https://caelusindustries.com",
    "description": "Autonomous maritime and counter-UAS defense systems for sovereign nations."
  })}/>

<!-- HERO -->
<section class="hero">
  <div class="hero-img-placeholder"></div>
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div style="display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center;width:100%">
      <h1>Autonomous Systems That Work Where It Matters</h1>
      <p>Caelus builds autonomous platforms for defense and industrial applications in high-consequence environments.</p>
    </div>
    <a href="/contact" class="btn-primary">
      <span class="btn-dot"></span>
      Request a demo
    </a>
  </div>
</section>

<!-- PRODUCTS -->
<div class="products-section">
  <div class="container">
    <div class="section-label">PRODUCTS</div>
    <div class="products-grid" style="flex-direction:row;flex-wrap:wrap;gap:20px;margin-top:40px;">
      <a href="/products/mukagen" style="flex:1;min-width:280px;text-decoration:none;">
        <div class="product-card" style="height:100%">
          <div class="product-img"><img src="/images/mukagen_preview.png" alt="MUKAGEN" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"/></div>
          <div class="product-info" style="padding:16px;">
            <div class="product-name">MUKAGEN</div>
            <div class="product-desc">Modular Counter-UAS Weapon Station</div>
            <div class="product-link">Learn more</div>
          </div>
        </div>
      </a>
      <a href="/products/yemoja-susv" style="flex:1;min-width:280px;text-decoration:none;">
        <div class="product-card" style="height:100%">
          <div class="product-img"><img src="/images/yemoja_preview.jpeg" alt="YEMOJA sUSV" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"/></div>
          <div class="product-info" style="padding:16px;">
            <div class="product-name">YEMOJA sUSV</div>
            <div class="product-desc">Autonomous Surface Patrol Vessel</div>
            <div class="product-link">Learn more</div>
          </div>
        </div>
      </a>
      <a href="/products/condor" style="flex:1;min-width:280px;text-decoration:none;">
        <div class="product-card" style="height:100%">
          <div class="product-img"><img src="/images/condor_preview.jpeg" alt="Condor" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;"/></div>
          <div class="product-info" style="padding:16px;">
            <div class="product-name">Condor</div>
            <div class="product-desc">Loitering Strike Munition</div>
            <div class="product-link">Learn more</div>
          </div>
        </div>
      </a>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- PRINCIPLES -->
<section class="principles-section">
  <div class="principles-bg"></div>
  <div class="principles-inner">
    <div class="principles-heading" style="animation:fadeUp 0.8s 0.2s both">
      <span class="serif">Built for vigilance</span>
      <span class="sans">Designed for Action</span>
    </div>
    <div class="principles-cards">
      <div class="principle-card" style="animation-delay:0.1s">
        <div class="principle-icon">
          <svg viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="21" cy="21" r="20" stroke="#000" stroke-width="1.5"/>
            <path d="M21 21 L21 8 A13 13 0 0 1 34 21 Z" fill="#000"/>
            <path d="M21 21 L8.5 27.5 A13 13 0 0 1 21 8 Z" fill="rgba(0,0,0,0.3)"/>
          </svg>
        </div>
        <div class="principle-title">Clarity drives security</div>
        <p class="principle-body">We believe superior operations start with superior intelligence: detected, analyzed, and actionable.</p>
      </div>
      <div class="principle-card" style="animation-delay:0.2s">
        <div class="principle-icon">
          <svg viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="21" cy="21" r="13" stroke="#000" stroke-width="1.5"/>
            <ellipse cx="21" cy="21" rx="5" ry="13" stroke="#000" stroke-width="1.5"/>
            <line x1="8" y1="21" x2="34" y2="21" stroke="#000" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="principle-title">Defense is a systems challenge</div>
        <p class="principle-body">We engineer platforms that help teams integrate surveillance, threats, and response across unmanned assets.</p>
      </div>
      <div class="principle-card" style="animation-delay:0.3s">
        <div class="principle-icon">
          <svg viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 32 L32 10" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M20 10 L32 10 L32 22" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="principle-title">Readiness over rigidity</div>
        <p class="principle-body">We enable real-world dominance, guiding forces from strategy to mission-critical execution.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<aside class="cta-aside">
  <h4>Ready to achieve your vigilance goals?</h4>
  <a href="/contact" class="btn-dark">
    <span style="width:4px;height:4px;border-radius:50%;background:#fff"></span>
    Request a demo
  </a>
</aside>

</Layout>
